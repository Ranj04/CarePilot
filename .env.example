HYDRADB_API_KEY=
HYDRADB_BASE_URL=                    # from the HydraDB dashboard
HYDRADB_TENANT_ID=default-tenant      # set to carepilot or whatever you create in HydraDB
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1/
NEBIUS_CHAT_MODEL=                   # the tool-calling model id from the playground
# NEBIUS_EMBED_MODEL=                # only if HydraDB requires you to supply your own vectors

# Stretch feature flag — chart import ("Connect health records"). Off by default;
# set to 1 to show the import button in the UI. MVP works fine without it.
# NEXT_PUBLIC_FEATURE_CHART_IMPORT=1
